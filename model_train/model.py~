    """Configuration class for ByteFormer model sizes."""
    
    MODES = {
        "tiny": {"embed_dim": 192, "n_layers": 12, "n_heads": 3, "ffn_dim": 768},
        "small": {"embed_dim": 384, "n_layers": 12, "n_heads": 6, "ffn_dim": 1536},
